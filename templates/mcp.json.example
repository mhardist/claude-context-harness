{
  "$comment": "Example MCP server config (~/.claude.json mcpServers section, or .mcp.json in a project). NEVER hardcode API keys — use ${ENV_VAR} expansion. Philosophy: keep MCP servers OUT of your default config and activate on demand via the /mcp-activate-* commands in the working-style plugin — every always-on MCP server costs context in every session.",
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${TWENTY_FIRST_API_KEY}"
      }
    }
  }
}
